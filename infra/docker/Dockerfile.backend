FROM rust:1-bookworm AS build
WORKDIR /app
COPY backend/Cargo.toml backend/Cargo.lock ./backend/
COPY backend/src ./backend/src
WORKDIR /app/backend
RUN cargo build --release

FROM debian:bookworm-slim
RUN apt-get update && apt-get install -y --no-install-recommends openssh-client ca-certificates && rm -rf /var/lib/apt/lists/*
WORKDIR /app
COPY --from=build /app/backend/target/release/openclaw-mission-control /usr/local/bin/openclaw-mission-control
EXPOSE 3001
CMD ["openclaw-mission-control"]
